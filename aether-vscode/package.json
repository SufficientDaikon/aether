{
  "name": "aether-vscode",
  "displayName": "AETHER — Multi-Agent Orchestrator",
  "description": "33 specialized AI agents with 3-tier hierarchy, visual orchestration, approval workflows, cost tracking, and codebase memory",
  "version": "0.1.0",
  "publisher": "sufficientdaikon",
  "repository": {
    "type": "git",
    "url": "https://github.com/aether-framework/aether"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.aether/config.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "aether.chat",
        "name": "aether",
        "fullName": "AETHER Agent Orchestrator",
        "description": "Multi-agent AI with 33 specialists — route tasks, review code, run tests, and architect systems",
        "isSticky": true,
        "commands": [
          {
            "name": "plan",
            "description": "Decompose task into sub-tasks with agent assignments"
          },
          {
            "name": "run",
            "description": "Execute task on best-fit agent"
          },
          {
            "name": "review",
            "description": "Code review with security analysis"
          },
          {
            "name": "test",
            "description": "Generate and run tests"
          },
          {
            "name": "debug",
            "description": "Investigate and fix errors"
          },
          {
            "name": "architect",
            "description": "System design and architecture"
          },
          {
            "name": "group",
            "description": "Multi-agent group discussion"
          },
          {
            "name": "status",
            "description": "Show tasks, costs, agent states"
          },
          {
            "name": "context",
            "description": "Switch agent namespace/context"
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aether-sidebar",
          "title": "AETHER",
          "icon": "media/aether-icon.svg"
        }
      ]
    },
    "views": {
      "aether-sidebar": [
        {
          "id": "aether.sidebar",
          "name": "AETHER",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "aether.dashboard",
        "title": "AETHER: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "aether.dashboard.overview",
        "title": "AETHER: Dashboard — Overview",
        "icon": "$(graph)"
      },
      {
        "command": "aether.dashboard.agents",
        "title": "AETHER: Dashboard — Agents",
        "icon": "$(organization)"
      },
      {
        "command": "aether.dashboard.tasks",
        "title": "AETHER: Dashboard — Tasks",
        "icon": "$(tasklist)"
      },
      {
        "command": "aether.dashboard.chat",
        "title": "AETHER: Dashboard — Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "aether.dashboard.approvals",
        "title": "AETHER: Dashboard — Approvals",
        "icon": "$(check-all)"
      },
      {
        "command": "aether.dashboard.memory",
        "title": "AETHER: Dashboard — Memory",
        "icon": "$(database)"
      },
      {
        "command": "aether.dashboard.settings",
        "title": "AETHER: Dashboard — Settings",
        "icon": "$(gear)"
      },
      {
        "command": "aether.runTask",
        "title": "AETHER: Run Task",
        "icon": "$(play)"
      },
      {
        "command": "aether.planTask",
        "title": "AETHER: Plan Task",
        "icon": "$(list-tree)"
      },
      {
        "command": "aether.showOrchestrator",
        "title": "AETHER: Show Orchestrator",
        "icon": "$(graph)"
      },
      {
        "command": "aether.showCosts",
        "title": "AETHER: Show Cost Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "aether.showMemory",
        "title": "AETHER: Show Memory Explorer",
        "icon": "$(database)"
      },
      {
        "command": "aether.showSettings",
        "title": "AETHER: Edit Settings",
        "icon": "$(gear)"
      },
      {
        "command": "aether.switchContext",
        "title": "AETHER: Switch Context",
        "icon": "$(layers)"
      },
      {
        "command": "aether.approveAll",
        "title": "AETHER: Approve All Pending",
        "icon": "$(check-all)"
      },
      {
        "command": "aether.rejectAll",
        "title": "AETHER: Reject All Pending",
        "icon": "$(close-all)"
      }
    ],
    "menus": {
      "view/item/context": [],
      "view/title": []
    },
    "configuration": {
      "title": "AETHER",
      "properties": {
        "aether.runtimePath": {
          "type": "string",
          "default": "",
          "description": "Path to AETHER installation directory. Auto-detected from workspace .aether/ if empty."
        },
        "aether.autoApprove": {
          "type": "string",
          "enum": [
            "none",
            "workers",
            "all"
          ],
          "default": "none",
          "description": "Auto-approve file changes from which agent tiers",
          "enumDescriptions": [
            "Require manual approval for all changes",
            "Auto-approve worker agent changes, require approval for managers and masters",
            "Auto-approve all changes (not recommended)"
          ]
        },
        "aether.budgetLimit": {
          "type": "number",
          "default": 0,
          "description": "Max spend per session in USD (0 = unlimited)"
        },
        "aether.showCostInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show running cost in the status bar"
        },
        "aether.defaultContext": {
          "type": "string",
          "default": "default",
          "description": "Default agent context/namespace to use"
        }
      }
    },
    "languages": [
      {
        "id": "synapse",
        "aliases": [
          "Synapse",
          "syn"
        ],
        "extensions": [
          ".syn"
        ],
        "configuration": "./language/synapse-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "synapse",
        "scopeName": "source.synapse",
        "path": "./language/synapse.tmLanguage.json"
      }
    ],
    "keybindings": [
      {
        "command": "aether.dashboard",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src/",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "@types/prismjs": "^1.26.6",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.0.0",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.24.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "markdown-it": "^14.1.1",
    "preact": "^10.28.4",
    "prismjs": "^1.30.0",
    "zustand": "^5.0.11"
  }
}
